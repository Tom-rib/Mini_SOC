<!--
=============================================================================
RÈGLES WAZUH - DÉTECTION BRUTE FORCE SSH
=============================================================================
Chemin: /var/ossec/etc/rules/local_rules.xml (sur le Wazuh Manager)
Usage: Détecter les tentatives de brute force sur SSH
Redémarrer: sudo systemctl restart wazuh-manager
=============================================================================
-->

<group name="ssh,authentication,brute_force,">

  <!--
  ==========================================================================
  RÈGLE 1: DÉTECTION BRUTE FORCE SSH - 5 ÉCHECS EN 2 MINUTES
  ==========================================================================
  Déclenche une alerte si 5 tentatives échouées depuis la même IP en 2 min
  Niveau: 10 (Critique)
  -->
  <rule id="100001" level="10" frequency="5" timeframe="120">
    <if_matched_sid>5710</if_matched_sid>
    <description>SSH Brute Force - 5 tentatives échouées en 2 minutes depuis $(src_ip)</description>
    <same_source_ip />
    <group>authentication_failures,brute_force,pci_dss_11.4,gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_SI.4,tsc_CC6.1,tsc_CC6.8,tsc_CC7.2,tsc_CC7.3,</group>
  </rule>

  <!--
  ==========================================================================
  RÈGLE 2: BRUTE FORCE SSH AGRESSIF - 10 ÉCHECS EN 5 MINUTES
  ==========================================================================
  Attaque plus soutenue
  Niveau: 12 (Critique++)
  -->
  <rule id="100002" level="12" frequency="10" timeframe="300">
    <if_matched_sid>5710</if_matched_sid>
    <description>SSH Brute Force AGRESSIF - 10 tentatives en 5 minutes depuis $(src_ip)</description>
    <same_source_ip />
    <options>no_email_alert</options>
    <group>authentication_failures,brute_force,attack,pci_dss_11.4,</group>
  </rule>

  <!--
  ==========================================================================
  RÈGLE 3: CONNEXION ROOT SSH (INTERDIT)
  ==========================================================================
  Déclenche si quelqu'un tente de se connecter en root
  Niveau: 8 (Alerte importante)
  -->
  <rule id="100003" level="8">
    <if_sid>5710</if_sid>
    <user>root</user>
    <description>Tentative de connexion SSH en tant que ROOT (INTERDIT) depuis $(src_ip)</description>
    <group>invalid_login,authentication_failed,policy_violation,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>

  <!--
  ==========================================================================
  RÈGLE 4: ÉCHEC AUTHENTIFICATION PAR CLÉ SSH
  ==========================================================================
  Alerte si la clé SSH est refusée
  Niveau: 6 (Medium)
  -->
  <rule id="100004" level="6">
    <if_sid>5709</if_sid>
    <match>publickey</match>
    <description>Échec d'authentification par clé SSH depuis $(src_ip) pour l'utilisateur $(user)</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>

  <!--
  ==========================================================================
  RÈGLE 5: CONNEXION SSH DEPUIS IP ÉTRANGÈRE
  ==========================================================================
  Alerte si connexion depuis une IP hors du réseau local
  ⚠️ À ADAPTER: Modifier la regex selon votre subnet
  Niveau: 7 (Medium-High)
  -->
  <rule id="100005" level="7">
    <if_sid>5715</if_sid>
    <srcip>!192.168.100.0/24</srcip>
    <description>Connexion SSH RÉUSSIE depuis IP EXTERNE: $(src_ip) - Utilisateur: $(user)</description>
    <group>authentication_success,external_access,pci_dss_10.2.5,gdpr_IV_32.2,</group>
  </rule>

  <!--
  ==========================================================================
  RÈGLE 6: MULTIPLES CONNEXIONS DEPUIS UNE MÊME IP
  ==========================================================================
  Détecte si une IP ouvre trop de connexions SSH simultanées
  Niveau: 8
  -->
  <rule id="100006" level="8" frequency="8" timeframe="60">
    <if_matched_sid>5715</if_matched_sid>
    <description>Connexions SSH multiples (8+) depuis $(src_ip) en 1 minute</description>
    <same_source_ip />
    <group>authentication_success,suspicious_activity,</group>
  </rule>

  <!--
  ==========================================================================
  RÈGLE 7: CONNEXION SSH HORS HORAIRES NORMAUX
  ==========================================================================
  Alerte pour connexions SSH entre 22h et 6h
  Niveau: 6
  -->
  <rule id="100007" level="6">
    <if_sid>5715</if_sid>
    <time>22:00-06:00</time>
    <description>Connexion SSH hors horaires normaux (22h-6h) depuis $(src_ip) - Utilisateur: $(user)</description>
    <group>authentication_success,after_hours,policy_violation,</group>
  </rule>

  <!--
  ==========================================================================
  RÈGLE 8: USERNAME INVALIDE (utilisateur inexistant)
  ==========================================================================
  Quelqu'un teste des noms d'utilisateurs
  Niveau: 7
  -->
  <rule id="100008" level="7">
    <if_sid>5710</if_sid>
    <match>Invalid user</match>
    <description>Tentative SSH avec utilisateur INEXISTANT depuis $(src_ip)</description>
    <group>invalid_login,authentication_failed,reconnaissance,</group>
  </rule>

  <!--
  ==========================================================================
  RÈGLE 9: SCAN SSH (Plusieurs users testés rapidement)
  ==========================================================================
  Détecte un scan de noms d'utilisateurs
  Niveau: 10
  -->
  <rule id="100009" level="10" frequency="5" timeframe="60">
    <if_matched_sid>100008</if_matched_sid>
    <description>SCAN SSH détecté: Tentatives multiples avec users inexistants depuis $(src_ip)</description>
    <same_source_ip />
    <group>reconnaissance,attack,pci_dss_11.4,</group>
  </rule>

  <!--
  ==========================================================================
  RÈGLE 10: DÉCONNEXION SSH SUSPECTE (session très courte)
  ==========================================================================
  Session SSH qui dure moins de 10 secondes (suspect)
  Niveau: 5
  -->
  <rule id="100010" level="5">
    <if_sid>5751</if_sid>
    <match>session closed</match>
    <description>Session SSH très courte détectée pour $(user) depuis $(src_ip)</description>
    <group>session_closed,suspicious_activity,</group>
  </rule>

  <!--
  ==========================================================================
  RÈGLE 11: PORT SSH NON STANDARD UTILISÉ
  ==========================================================================
  Détecte les tentatives sur le port SSH custom
  Niveau: 4 (Info)
  -->
  <rule id="100011" level="4">
    <if_sid>5710</if_sid>
    <match>port 2222</match>
    <description>Tentative SSH sur port non-standard (2222) depuis $(src_ip)</description>
    <group>authentication_failed,non_standard_port,</group>
  </rule>

  <!--
  ==========================================================================
  RÈGLE 12: BRUTE FORCE RÉUSSI (après plusieurs échecs)
  ==========================================================================
  Connexion réussie APRÈS plusieurs échecs = compte compromis ?
  Niveau: 12 (Critique)
  -->
  <rule id="100012" level="12" frequency="1" timeframe="300">
    <if_matched_sid>5715</if_matched_sid>
    <if_matched_group>authentication_success</if_matched_group>
    <same_source_ip />
    <description>ALERTE: Connexion SSH RÉUSSIE après tentatives échouées depuis $(src_ip) - Compte $(user) possiblement compromis</description>
    <group>authentication_success,possible_breach,pci_dss_10.2.4,pci_dss_10.2.5,gdpr_IV_35.7.d,</group>
  </rule>

</group>

<!--
=============================================================================
RÉFÉRENCES DES SIDS WAZUH NATIFS
=============================================================================

5710 = sshd: Attempt to login using a non-existent user
5709 = sshd: authentication failed
5715 = sshd: authentication success
5751 = sshd: session closed

Pour voir toutes les règles SSH natives:
grep -r "5710\|5709\|5715" /var/ossec/ruleset/rules/

=============================================================================
INSTALLATION ET ACTIVATION
=============================================================================

1. Sur le serveur Wazuh Manager:
   sudo nano /var/ossec/etc/rules/local_rules.xml

2. Copier tout le contenu de ce fichier dans local_rules.xml

3. Vérifier la syntaxe:
   sudo /var/ossec/bin/wazuh-logtest

4. Redémarrer Wazuh:
   sudo systemctl restart wazuh-manager

5. Vérifier les logs:
   sudo tail -f /var/ossec/logs/ossec.log

6. Tester avec un brute force:
   # Depuis une autre machine:
   for i in {1..10}; do ssh root@IP_CIBLE -p 2222; done

7. Vérifier les alertes dans Wazuh Web UI:
   Dashboard > Security Events > SSH

=============================================================================
NIVEAUX DE GRAVITÉ WAZUH
=============================================================================

0  = Ignored
1  = None
2  = System low priority
3  = Successful/Authorized
4  = System low priority
5  = User generated
6  = Low relevance attack
7  = "Bad word" matching
8  = First time seen
9  = Error from invalid source
10 = Multiple user generated errors
11 = Integrity checking warning
12 = High importance event
13 = Unusual error (high importance)
14 = High importance security event
15 = Severe attack

=============================================================================
PERSONNALISATION
=============================================================================

Pour ajuster les seuils:
- frequency="X" : Nombre d'occurrences
- timeframe="Y" : Période en secondes
- same_source_ip : Même IP source
- same_user : Même utilisateur

Exemple: Détecter 3 échecs en 1 minute
<rule id="100020" level="8" frequency="3" timeframe="60">

=============================================================================
-->
